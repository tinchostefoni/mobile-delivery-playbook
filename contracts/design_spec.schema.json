{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zafirus.tech/contracts/design_spec.schema.json",
  "title": "design_spec",
  "type": "object",
  "required": ["meta", "figma", "node_specs", "unknowns", "assumptions"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["contract_version", "generated_at", "agent"],
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": "1.0.0" },
        "generated_at": { "type": "string", "format": "date-time" },
        "agent": { "type": "string", "const": "figma-intake" }
      }
    },
    "figma": {
      "type": "object",
      "required": ["file_url", "file_key", "node_ids", "mcp_status"],
      "additionalProperties": false,
      "properties": {
        "file_url": { "type": "string", "format": "uri" },
        "file_key": { "type": "string", "minLength": 2 },
        "node_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "mcp_status": { "type": "string", "enum": ["connected", "degraded", "unavailable"] }
      }
    },
    "design_tokens": {
      "type": "object",
      "additionalProperties": true
    },
    "node_specs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node_id", "name", "type"],
        "additionalProperties": false,
        "properties": {
          "node_id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "size": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "width": { "type": "number" },
              "height": { "type": "number" }
            }
          },
          "states": { "type": "array", "items": { "type": "string" } },
          "interactions": { "type": "array", "items": { "type": "string" } },
          "assets": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "responsive_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "breakpoints": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string", "pattern": "^MISSING:" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^ASSUMPTION:" }
    }
  }
}
