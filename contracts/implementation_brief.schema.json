{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zafirus.tech/contracts/implementation_brief.schema.json",
  "title": "implementation_brief",
  "type": "object",
  "required": ["meta", "objective", "work_items", "constraints", "validation_plan", "open_items", "assumptions"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["contract_version", "generated_at", "agent"],
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": "1.0.0" },
        "generated_at": { "type": "string", "format": "date-time" },
        "agent": { "type": "string", "const": "spec-filler" }
      }
    },
    "objective": { "type": "string", "minLength": 5 },
    "work_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "description", "files"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["backend", "frontend", "backend-client", "frontend-ui", "infra", "qa"] },
          "description": { "type": "string", "minLength": 5 },
          "files": { "type": "array", "items": { "type": "string" } },
          "acceptance_mapping": { "type": "array", "items": { "type": "string" } },
          "figma_mapping": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "constraints": {
      "type": "object",
      "required": ["no_auto_commit", "dependency_policy"],
      "additionalProperties": false,
      "properties": {
        "must_not_change": { "type": "array", "items": { "type": "string" } },
        "no_auto_commit": { "type": "boolean", "const": true },
        "dependency_policy": { "type": "string" }
      }
    },
    "validation_plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit_tests": { "type": "array", "items": { "type": "string" } },
        "integration_tests": { "type": "array", "items": { "type": "string" } },
        "visual_checks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "open_items": {
      "type": "array",
      "items": { "type": "string", "pattern": "^MISSING:" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^ASSUMPTION:" }
    }
  }
}
