# .env.playbook — secrets and environment-specific values for the playbook pipeline
# Copy this file to <REPO_ROOT>/.env.playbook and fill in your values.
# This file is .gitignored. Never commit .env.playbook.

# GitLab personal access token with api + write_repository scopes.
# Required for automated MR creation via create_mr.sh.
GITLAB_TOKEN=

# GitLab API base URL (default: https://gitlab.com/api/v4).
# Override for self-hosted GitLab instances.
GITLAB_API_URL=https://gitlab.com/api/v4

# Google Chat incoming webhook URL.
# Required when NOTIFY_GOOGLE_CHAT=true.
GOOGLE_CHAT_WEBHOOK_URL=
